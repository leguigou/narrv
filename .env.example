APP_NAME=Narrv
APP_VERSION=1.0.0
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=sqlite
DB_DATABASE=database/narrv.sqlite

QUEUE_CONNECTION=database

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_INPUT_CHARACTERS=45000
YT_DLP_PATH=yt-dlp
YT_DLP_SLEEP_REQUESTS=1
YT_DLP_RETRIES=5
YT_DLP_RETRY_SLEEP=http:exp=1:20
YT_DLP_JS_RUNTIMES=node
YOUTUBE_COOKIES_PATH=storage/app/youtube-cookies.txt
YOUTUBE_COOKIES_BASE64=

ADMIN_PASSWORD=

LOG_CHANNEL=stack
LOG_LEVEL=debug
